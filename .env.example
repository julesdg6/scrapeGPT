# Ollama connection - set to the URL of your Ollama container or instance
OLLAMA_HOST=http://ollama:11434

# Ollama model to use (must be pulled into Ollama beforehand)
OLLAMA_MODEL=qwen:0.5b

# Port to expose the Gradio web UI on the host
GRADIO_PORT=7860

# Telegram Bot token (only required when running scrapeGPT.py Telegram bot)
TELEGRAM_BOT_TOKEN=
