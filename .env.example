# Ollama connection - set to the URL of your Ollama container or instance
OLLAMA_HOST=http://ollama:11434

# Ollama model to use (must be pulled into Ollama beforehand)
OLLAMA_MODEL=qwen:0.5b

# Ollama vision/multimodal model for image analysis (must be pulled into Ollama beforehand)
# Pull with: ollama pull llava
OLLAMA_VISION_MODEL=llava

# Port to expose the Gradio web UI on the host
GRADIO_PORT=7860

# Telegram Bot token (only required when running scrapeGoat.py Telegram bot)
TELEGRAM_BOT_TOKEN=

# Path to the shared JSON config file (stores allowed Telegram user IDs, etc.)
# Must point to a persistent volume in Docker; defaults to config.json in the working directory.
CONFIG_PATH=/data/config.json

# Optional: URL of the WhisperLive service for GPU-accelerated speech transcription.
# Set to http://whisperlive:9090 when using the bundled whisperlive service in docker-compose
# (start it with: docker compose --profile whisper up -d).
# Leave empty to disable speech transcription (music analysis still works without it).
# Upgrade from local openai-whisper: set this to your WhisperLive instance URL and
# the openai-whisper package is no longer required.
WHISPERLIVE_HOST=

# PyTorch build flavour (only used when building the image with docker compose build).
# Leave as 'cpu' for a smaller image (~1.5 GB lighter, no NVIDIA GPU required).
# Set to a CUDA tag (e.g. cu121, cu118) to include NVIDIA GPU support.
# Example: PYTORCH_FLAVOR=cu121
PYTORCH_FLAVOR=cpu
